# === Обов'язкові ===

# Telegram Bot Token (отримати у @BotFather)
BOT_TOKEN=your_bot_token_here

# Telegram Chat ID групи (від'ємне число для груп, наприклад: -1001234567890)
CHAT_ID=-1001234567890

# Учасники у форматі Ім'я=@username через кому
PARTICIPANTS=Юра=@Iurook,Толя=@anatoliireva,Діма=@dlevinn

# === Необов'язкові ===

# Часовий пояс для розкладу нагадувань (12:00/18:00)
TIMEZONE=Europe/Warsaw

# Кількість останніх фраз, які не повторюються
PHRASE_HISTORY_SIZE=10

# --- AI-фічі (/ask, згадки бота, п'ятничний AI-аналіз тижня) ---
# Без цього ключа AI-фічі просто вимкнені, решта бота працює як завжди.
# Отримати ключ: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001

# --- Персистентність стану (переживає передеплой на Fly.io/Railway) ---
# Без цих двох змінних стан живе тільки на локальному диску контейнера
# і губиться при кожному передеплої. З ними — бот сам комітить
# data/state.json назад у твій GitHub-репозиторій після кожної зміни.
# GITHUB_TOKEN: Settings -> Developer settings -> Personal access tokens ->
#               Fine-grained token з правом "Contents: Read and write"
#               саме для цього репозиторію.
# GITHUB_REPO:  у форматі owner/repo, наприклад DmitriiLevin/pushup-bot
GITHUB_TOKEN=
GITHUB_REPO=
