# Telegram Bot Token (отримати у @BotFather)
BOT_TOKEN=your_bot_token_here

# Telegram Chat ID групи (від'ємне число для груп, наприклад: -1001234567890)
CHAT_ID=-1001234567890

# Учасники у форматі Ім'я=@username через кому
PARTICIPANTS=Діма=@dlevinn,Толя=@anatoliireva,Юра=@lurook

# Час щоденного нагадування у форматі HH:MM
REMINDER_TIME=12:00

# Timezone для нагадування (стандарт IANA, наприклад: Europe/Warsaw, Europe/Kyiv, UTC)
REMINDER_TIMEZONE=Europe/Warsaw

# Час підсумку тижня (щоп'ятниці)
FRIDAY_SUMMARY_TIME=18:00

# Кількість останніх фраз, які не повторюються
PHRASE_HISTORY_SIZE=10
